<div class="pf2eaw">
  <header class="pf2eaw-header">
    <h2>{{actor.name}}</h2>
    <p>{{localize "PF2EAW.Initialized"}}</p>
  </header>

  <section class="pf2eaw-body-grid">
    {{#each zones}}
      <button class="pf2eaw-zone pf2eaw-status-{{status}}" data-zone-id="{{id}}">
        <span class="pf2eaw-zone-label">{{localize label}}</span>
      </button>
    {{/each}}
  </section>

  {{#unless canEdit}}
    <p class="pf2eaw-note">{{localize "PF2EAW.ReadOnly"}}</p>
  {{/unless}}
</div>
_openAddWoundDialog(zoneId) {
  let options = WOUND_SEVERITIES.map(sev => {
    return `<option value="${sev}">${game.i18n.localize(`PF2EAW.Severity.${sev}`)}</option>`;
  }).join("");

  new Dialog({
    title: game.i18n.localize("PF2EAW.AddWoundTitle"),
    content: `
      <form>
        <div class="form-group">
          <label>${game.i18n.localize("PF2EAW.SelectSeverity")}</label>
          <select id="pf2eaw-severity">
            ${options}
          </select>
        </div>
      </form>
    `,
    buttons: {
      confirm: {
        label: game.i18n.localize("PF2EAW.Confirm"),
        callback: async (html) => {
          const severity = html.find("#pf2eaw-severity").val();
          await this._addWound(zoneId, severity);
        }
      },
      cancel: {
        label: game.i18n.localize("PF2EAW.Cancel")
      }
    }
  }).render(true);
}
async _addWound(zoneId, severity) {
  const wounds = foundry.utils.getProperty(this.actor, "flags.pf2eaw.wounds") || [];

  wounds.push({
    id: randomID(),
    zone: zoneId,
    severity: severity,
    createdAt: Date.now()
  });

  await this.actor.setFlag("pf2eaw", "wounds", wounds);

  ui.notifications.info(`Wound added: ${zoneId} (${severity})`);
}